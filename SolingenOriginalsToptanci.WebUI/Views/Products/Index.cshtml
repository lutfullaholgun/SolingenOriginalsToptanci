@model IEnumerable<SolingenOriginalsToptanci.Models.Product>
@{
    ViewData["Title"] = "Ürün Listesi";
}

<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold">Ürünler</h2>
        <a asp-action="Create" class="btn btn-success">+ Yeni Ürün Ekle</a>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-warning text-center">
            Henüz ürün eklenmemiş.
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-3 g-4">
            @foreach (var product in Model)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm border-0">
                        <img src="@product.ImageUrl" class="card-img-top" style="height: 200px; object-fit: cover;" alt="@product.Name" />
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title">@product.Name</h5>
                            <p class="card-text text-muted mb-1">Model: @product.Model</p>
                            <p class="card-text fw-semibold text-primary">@product.Price ₺</p>
                            <div class="mt-auto d-flex justify-content-between">
                                <a asp-action="Details" asp-route-id="@product.Id" class="btn btn-outline-primary btn-sm">Detay</a>
                                <a asp-action="Edit" asp-route-id="@product.Id" class="btn btn-outline-warning btn-sm">Düzenle</a>
                                <a asp-action="Delete" asp-route-id="@product.Id" class="btn btn-outline-danger btn-sm">Sil</a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
