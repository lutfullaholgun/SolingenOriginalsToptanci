@model IEnumerable<SolingenOriginalsToptanci.Models.Product>
@using Microsoft.AspNetCore.Identity

@{
    ViewData["Title"] = "Ürünler";
    bool isAdmin = User.IsInRole("Admin");
}

<div class="container py-4">
    <h2 class="text-center mb-4">Ürünler</h2>

    @if (isAdmin)
    {
        <div class="text-end mb-3">
            <a asp-action="Create" class="btn btn-success">
                <i class="bi bi-plus-circle"></i> Ürün Ekle
            </a>
        </div>
    }

    <div class="row row-cols-1 row-cols-md-3 g-4">
        @foreach (var product in Model)
        {
            <div class="col">
                <div class="card h-100 shadow-sm border-0">
                    <a asp-controller="Products" asp-action="Details" asp-route-id="@product.Id" class="stretched-link text-decoration-none text-dark">
                        <img src="@product.ImageUrl" class="card-img-top" alt="@product.Name" style="height: 200px; object-fit: cover;" />
                    </a>
                    <div class="card-body">
                        <h5 class="card-title fw-semibold">@product.Name</h5>
                        <p class="card-text text-muted mb-1">Model: @product.Model</p>
                        <p class="card-text text-muted mb-1">Renk: @product.Color</p>
                        <p class="card-text fw-bold text-primary">$@product.Price.ToString("F2")</p>
                    </div>
                    <div class="card-footer bg-white border-0 d-flex justify-content-between align-items-center">
                        <small class="text-muted">@product.Stock adet stokta</small>

                        <form asp-controller="Cart" asp-action="AddToCart" method="post" class="m-0">
                            <input type="hidden" name="id" value="@product.Id" />
                            <button type="submit" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-cart-plus"></i> Sepete Ekle
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
