@model SolingenOriginalsToptanci.Models.Product

@{
    ViewData["Title"] = "Yeni Ürün Ekle";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-lg border-0">
                <div class="card-header bg-primary text-white text-center">
                    <h3 class="mb-0">Yeni Ürün Ekle</h3>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Create" method="post" class="needs-validation" novalidate>
                        <div class="mb-3">
                            <label asp-for="Name" class="form-label fw-semibold">Ürün Adı</label>
                            <input asp-for="Name" class="form-control" placeholder="Örn: Şef Bıçağı" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Color" class="form-label fw-semibold">Renk</label>
                            <input asp-for="Color" class="form-control" placeholder="Örn: Siyah" />
                            <span asp-validation-for="Color" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Model" class="form-label fw-semibold">Model</label>
                            <input asp-for="Model" class="form-control" placeholder="Örn: 2024X Premium" />
                            <span asp-validation-for="Model" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Price" class="form-label fw-semibold">Fiyat</label>
                            <input asp-for="Price" type="number" step="0.01" class="form-control" placeholder="Örn: 1499.99" />
                            <span asp-validation-for="Price" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="ImageUrl" class="form-label fw-semibold">Görsel URL</label>
                            <input asp-for="ImageUrl" class="form-control" placeholder="Örn: /images/chef-knife.jpg" />
                            <span asp-validation-for="ImageUrl" class="text-danger small"></span>
                        </div>

                        <div class="d-flex justify-content-between mt-4">
                            <button type="submit" class="btn btn-success px-4">Kaydet</button>
                            <a asp-action="Index" class="btn btn-outline-secondary">İptal</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
