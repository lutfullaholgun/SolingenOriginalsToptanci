@model SolingenOriginalsToptanci.Models.Product

@{
    ViewData["Title"] = "Yeni Ürün Ekle";
}

<div class="container py-5">
    <form asp-action="Create" method="post" enctype="multipart/form-data">
        <div class="mb-4">
            <label asp-for="Name" class="form-label">Ürün Adı</label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="mb-4">
            <label asp-for="Color" class="form-label">Renk</label>
            <input asp-for="Color" class="form-control" />
        </div>

        <div class="mb-4">
            <label asp-for="Model" class="form-label">Model</label>
            <input asp-for="Model" class="form-control" />
        </div>

        <div class="mb-4">
            <label asp-for="Price" class="form-label">Fiyat</label>
            <input asp-for="Price" class="form-control" />
        </div>

        <div class="mb-4">
            <label asp-for="Stock" class="form-label">Stok</label>
            <input asp-for="Stock" class="form-control" />
        </div>

        <div class="mb-4">
            <label asp-for="Description" class="form-label">Açıklama</label>
            <textarea asp-for="Description" class="form-control"></textarea>
        </div>

        <div class="mb-4">
            <label asp-for="ImageFile" class="form-label">Ürün Görseli</label>
            <input asp-for="ImageFile" type="file" class="form-control" />
        </div>

        <div class="form-check mb-4">
            <input asp-for="IsFeatured" class="form-check-input" />
            <label asp-for="IsFeatured" class="form-check-label">Öne Çıkan</label>
        </div>

        <button type="submit" class="btn btn-primary">Kaydet</button>
    </form>

</div>
