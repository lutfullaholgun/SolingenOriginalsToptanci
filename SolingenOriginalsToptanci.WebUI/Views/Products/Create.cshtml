@model SolingenOriginalsToptanci.Models.Product

@{
    ViewData["Title"] = "Yeni Ürün Ekle";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-7">
            <div class="card shadow rounded-4 border-0">
                <div class="card-header bg-dark text-white rounded-top-4 text-center py-4">
                    <h2 class="mb-0">Yeni Ürün Ekle</h2>
                    <p class="mb-0 small">Lütfen ürün bilgilerini eksiksiz doldurun</p>
                </div>
                <div class="card-body px-5 py-4">
                    <form asp-action="Create" method="post" novalidate>
                        <div class="mb-4">
                            <label asp-for="Name" class="form-label">Ürün Adı</label>
                            <input asp-for="Name" class="form-control form-control-lg" placeholder="Örn: Şef Bıçağı" />
                            <span asp-validation-for="Name" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Color" class="form-label">Renk</label>
                            <input asp-for="Color" class="form-control form-control-lg" placeholder="Örn: Siyah" />
                            <span asp-validation-for="Color" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Model" class="form-label">Model</label>
                            <input asp-for="Model" class="form-control form-control-lg" placeholder="Örn: 2024X Premium" />
                            <span asp-validation-for="Model" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Price" class="form-label">Fiyat</label>
                            <input asp-for="Price" type="number" step="0.01" class="form-control form-control-lg" placeholder="Örn: 1499.99" />
                            <span asp-validation-for="Price" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="ImageUrl" class="form-label">Görsel URL</label>
                            <input asp-for="ImageUrl" class="form-control form-control-lg" placeholder="Örn: /images/chef-knife.jpg" />
                            <span asp-validation-for="ImageUrl" class="text-danger small"></span>
                        </div>

                        <div class="form-check mb-4">
                            <input asp-for="IsFeatured" class="form-check-input" />
                            <label asp-for="IsFeatured" class="form-check-label">Öne Çıkan Ürün</label>
                        </div>

                        <div class="d-flex justify-content-end gap-3">
                            <a asp-action="Index" class="btn btn-outline-secondary px-4">İptal</a>
                            <button type="submit" class="btn btn-success px-5">Kaydet</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
