@model SolingenOriginalsToptanci.Models.Product

@{
    ViewData["Title"] = "Ürünü Sil";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow border-0">
                <div class="card-header bg-danger text-white text-center">
                    <h3 class="mb-0">Ürünü Sil</h3>
                </div>
                <div class="card-body p-4">
                    <h5 class="mb-3 text-danger">Bu ürünü silmek istediğinizden emin misiniz?</h5>
                    <dl class="row">
                        <dt class="col-sm-3">Ad</dt>
                        <dd class="col-sm-9">@Model.Name</dd>

                        <dt class="col-sm-3">Model</dt>
                        <dd class="col-sm-9">@Model.Model</dd>

                        <dt class="col-sm-3">Fiyat</dt>
                        <dd class="col-sm-9">@Model.Price ₺</dd>
                    </dl>

                    <form asp-action="Delete" method="post">
                        <input type="hidden" asp-for="Id" />
                        <div class="d-flex justify-content-between">
                            <button type="submit" class="btn btn-danger px-4">Sil</button>
                            <a asp-action="Index" class="btn btn-outline-secondary">İptal</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
