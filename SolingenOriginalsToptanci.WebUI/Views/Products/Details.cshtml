@model SolingenOriginalsToptanci.Models.Product

@{
    ViewBag.Title = "Ürün Detayı";
}

<div class="container my-5">
    <div class="row g-5 align-items-center">
        <!-- Ürün Görseli -->
        <div class="col-md-6 text-center">
            <img src="@Model.ImageUrl" alt="@Model.Name" class="img-fluid rounded shadow-sm" style="max-height: 500px; object-fit: contain;" />
        </div>

        <!-- Ürün Bilgileri -->
        <div class="col-md-6">
            <h1 class="display-6 fw-bold">@Model.Name</h1>
            <p class="text-muted fs-5 mb-1">Model: @Model.Model</p>
            <p class="text-muted fs-5 mb-3">Renk: @Model.Color</p>

            <div class="mb-4">
                <span class="h4 fw-bold text-primary">@Model.Price.ToString("C")</span>
                <span class="text-muted ms-3">(@Model.Stock adet stokta)</span>
            </div>

            <p class="lead">@Model.Description</p>

            <!-- Sepete Ekle Form -->
            <form asp-controller="Products" asp-action="AddToCart" method="post" class="mt-4">
                @Html.AntiForgeryToken()
                <input type="hidden" name="productId" value="@Model.Id" />

                <div class="input-group" style="max-width: 200px;">
                    <input type="number" class="form-control text-center" value="1" min="1" disabled />
                    <button class="btn btn-primary w-100" type="submit">
                        <i class="bi bi-cart-fill me-1"></i> Sepete Ekle
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>
