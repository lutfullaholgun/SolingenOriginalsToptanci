<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SolingenOriginalsToptanci.WebUI</title>
    <script type="importmap"></script>
    <!-- Yeni Stylesheet linki -->
    <link rel="stylesheet" href="~/theme/css/styles.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">

</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index">Solingen Originals Toptancı Sayfası</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Index">Anasayfa</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
                        </li>
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle text-dark" href="#" id="productsDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                Ürünlerimiz
                            </a>
                            <ul class="dropdown-menu" aria-labelledby="productsDropdown">
                                <li><a class="dropdown-item" asp-controller="Products" asp-action="Index">Tüm Ürünler</a></li>
                                <li><a class="dropdown-item" asp-controller="Products" asp-action="Index" asp-route-color="Meyve">Meyve Bıçakları</a></li>
                                <li><a class="dropdown-item" asp-controller="Products" asp-action="Index" asp-route-color="Günlük">Günlük Kullanım Bıçaklar</a></li>
                                <li><a class="dropdown-item" asp-controller="Products" asp-action="Index" asp-route-model="Kasap">Kasap Bıçakları</a></li>
                                <li><a class="dropdown-item" asp-controller="Products" asp-action="Index" asp-route-model="Gündelik">Gündelik Bıçaklar</a></li>
                            </ul>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2025 - SolingenOriginalsToptanci.WebUI - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>

    <!-- Eski JS dosyalarının yerine yeni dosyayı ekliyoruz -->
    <script src="~/theme/js/scripts.js"></script>

    <!-- Geriye kalan eski script dosyalarını da ekleyelim -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>
