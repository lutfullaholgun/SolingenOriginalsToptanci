@{
    ViewData["Title"] = "Admin Paneli";
}

<div class="container mt-5">
    <h1 class="mb-4">Admin Paneli</h1>

    <div class="row">
        <div class="col-md-6 mb-4">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">Ürün Yönetimi</h5>
                    <p class="card-text">Ürünleri ekle, güncelle veya sil.</p>
                    <a href="/Products/Index" class="btn btn-primary">Ürün Listesi</a>
                </div>
            </div>
        </div>
        <div class="col-md-6 mb-4">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">Kullanıcı Yönetimi</h5>
                    <p class="card-text">Kullanıcıları görüntüle ve rolleri düzenle.</p>
                    <a href="/Admin/Users" class="btn btn-secondary">Kullanıcı Listesi</a>
                </div>
            </div>
        </div>
    </div>
</div>
