@model List<SolingenOriginalsToptanci.WebUI.Models.CartItem>
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>Fatura</title>
    <style>
        table {
            width: 100%;
            border-collapse: collapse;
        }

        th, td {
            border: 1px solid #444;
            padding: 5px;
        }

        tfoot td {
            font-weight: bold;
        }
    </style>
</head>
<body>
    <h1>Solingen Originals Toptancı Faturası</h1>
    <p>Tarih: @DateTime.Now:dd.MM.yyyy</p>
    <table>
        <thead><tr><th>Ürün</th><th>Adet</th><th>Birim Fiyat</th><th>Tutar</th></tr></thead>
        <tbody>
            @foreach (var i in Model)
            {
                <tr>
                    <td>@i.Name (@i.Color, @i.Model)</td>
                    <td>@i.Quantity</td>
                    <td>@i.Price.ToString("C")</td>
                    <td>@(i.Price * i.Quantity).ToString("C")</td>
                </tr>
            }
        </tbody>
        <tfoot>
            <tr>
                <td colspan="3" class="text-right">Genel Toplam:</td>
                <td>@Model.Sum(x => x.Price * x.Quantity).ToString("C")</td>
            </tr>
        </tfoot>
    </table>
</body>
</html>
